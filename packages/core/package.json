{
  "name": "@bamboo-editor/core",
  "version": "0.1.3",
  "description": "Core Tiptap extensions and controlled HTML utilities for Bamboo Editor.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "bamboo-editor",
    "editor",
    "rich-text",
    "tiptap",
    "html",
    "sanitize"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/longjianghu/bamboo-editor.git"
  },
  "homepage": "https://github.com/longjianghu/bamboo-editor#readme",
  "bugs": {
    "url": "https://github.com/longjianghu/bamboo-editor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-blockquote": "^2.11.5",
    "@tiptap/extension-character-count": "^2.11.5",
    "@tiptap/extension-code-block": "^2.11.5",
    "@tiptap/extension-hard-break": "^2.11.5",
    "@tiptap/extension-heading": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-list-item": "^2.11.5",
    "@tiptap/extension-ordered-list": "^2.11.5",
    "@tiptap/extension-bullet-list": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-horizontal-rule": "^2.11.5",
    "@tiptap/extension-text-align": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
